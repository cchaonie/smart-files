# PostgreSQL (local dev; Docker Compose overrides DATABASE_URL for the app service)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smartfiles?schema=public"

# Auth.js — generate e.g. openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# Public URL of the app (used by Auth.js)
AUTH_URL="http://localhost:3000"

# File storage root (default: ./data/storage)
UPLOAD_ROOT="./data/storage"

# Optional limits
# MAX_FILE_SIZE_BYTES=524288000
# DEFAULT_CHUNK_SIZE_BYTES=5242880
# MAX_CHUNKS=50000
