# ============================================
# Smart Files Backend Environment
# ============================================
# Copy to packages/backend/.env and fill in actual values
# cp .env.example packages/backend/.env

# --------------------------------------------
# Database
# --------------------------------------------
# PostgreSQL connection string
# Local development: postgresql://postgres:postgres@localhost:5432/smartfiles?schema=public
# Inside container:   postgresql://postgres:postgres@db:5432/smartfiles?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smartfiles?schema=public

# --------------------------------------------
# JWT Authentication
# --------------------------------------------
# Secret for signing JWT tokens (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-min-32-characters-long

# --------------------------------------------
# File Storage
# --------------------------------------------
# Root directory for uploaded files and temp chunks
UPLOAD_ROOT=./data/storage

# Max upload size in bytes (default 10 GiB)
MAX_FILE_SIZE_BYTES=10737418240

# --------------------------------------------
# Server
# --------------------------------------------
# API server port
PORT=4000

# Allowed CORS origins (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:19006

# Node environment
NODE_ENV=development
