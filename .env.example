# ============================================
# Smart Files 环境变量配置
# ============================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# --------------------------------------------
# 数据库配置
# --------------------------------------------
# PostgreSQL 连接字符串
# 格式: postgresql://用户名:密码@主机:端口/数据库名?schema=public
# 本地开发使用: postgresql://postgres:postgres@localhost:5432/smartfiles?schema=public
# 容器内使用: postgresql://postgres:postgres@db:5432/smartfiles?schema=public
DATABASE_URL=postgresql://postgres:postgres@db:5432/smartfiles?schema=public

# 容器内 PostgreSQL 配置（仅在 podman-compose.prod.yml 中使用）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=smartfiles

# --------------------------------------------
# 认证配置
# --------------------------------------------
# Next Auth 密钥，用于加密会话
# 生成方法: openssl rand -base64 32
# 必须至少 32 个字符
AUTH_SECRET=your-auth-secret-min-32-characters-long

# 应用访问 URL
# 本地开发: http://localhost:3000
# 生产环境: https://your-domain.com
AUTH_URL=http://localhost:3000

# --------------------------------------------
# 应用配置
# --------------------------------------------
# 应用端口（仅用于 podman-compose.prod.yml）
APP_PORT=3000

# 文件上传配置
# 最大文件大小（字节），默认 500MB
MAX_FILE_SIZE_BYTES=524288000

# 上传文件存储根目录（容器内路径，无需修改）
UPLOAD_ROOT=/data/storage

# --------------------------------------------
# 备份配置（可选）
# --------------------------------------------
# 备份目录
BACKUP_DIR=./backups

# 备份保留天数
BACKUP_RETENTION_DAYS=7

# 更新前是否自动备份（true/false）
BACKUP_BEFORE_UPDATE=false
