{
  "name": "smart-files",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "@types/react": "~19.1.10",
    "@types/react-dom": "^19.1.0"
  },
  "scripts": {
    "db:start": "podman run -d --name smart-files-db -p 127.0.0.1:5432:5432 -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=smartfiles -v ./data/postgres:/var/lib/postgresql/data:Z --replace postgres:16-alpine",
    "db:stop": "podman stop -t 5 smart-files-db && podman rm smart-files-db",
    "dev": "npm-run-all -p dev:backend dev:web",
    "dev:backend": "cd packages/backend && npm run start:dev",
    "dev:web": "cd packages/web && npm run dev",
    "prd:build": "npm-run-all -p prd:webbuild prd:backendbuild",
    "prd:webbuild": "cd packages/web && npm run build",
    "prd:backendbuild": "cd packages/backend && npm run build",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs smart-files-backend",
    "pm2:status": "pm2 status"
  },
  "devDependencies": {
    "@types/multer": "^2.1.0",
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "@img/sharp-libvips-linux-x64": "^1.3.0",
    "@nestjs/core": "^11.0.0",
    "jimp": "^1.6.1",
    "node-addon-api": "^8.8.0",
    "node-gyp": "^12.4.0"
  }
}
